import numpy as np
import matplotlib.pyplot as plt
from sklearn.datasets import make_classification
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import confusion_matrix, accuracy_score

# Generate dataset (DIFFERENT from hers)
X, y = make_classification(n_samples=200, n_features=2, random_state=42)

# Train model
model = LogisticRegression()
model.fit(X, y)

# Predictions
y_pred = model.predict(X)

print("Accuracy:", accuracy_score(y, y_pred))
print("Confusion Matrix:\n", confusion_matrix(y, y_pred))

## Results

The model achieves strong classification performance on the dataset.
The confusion matrix shows how well the model distinguishes between the two classes.

We observe that logistic regression performs well when the data is linearly separable.

# Plot decision boundary
plt.scatter(X[:,0], X[:,1], c=y, cmap='coolwarm')

x_min, x_max = plt.xlim()
y_min, y_max = plt.ylim()

xx, yy = np.meshgrid(
    np.linspace(x_min, x_max, 100),
    np.linspace(y_min, y_max, 100)
)

Z = model.predict(np.c_[xx.ravel(), yy.ravel()])
Z = Z.reshape(xx.shape)

plt.contour(xx, yy, Z, alpha=0.3)
plt.title("Decision Boundary")
plt.show()
